<!DOCTYPE html>
<html lang="zh-TW">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
    <title>專業記帳本</title>
    <style>
        :root {
            --green-theme: #8ba88e;
            --bg-light: #f4f6f4;
            --text-gray: #777;
            --exp-color: #c88c8c;
        }

        body { font-family: -apple-system, sans-serif; margin: 0; background: var(--bg-light); height: 100vh; overflow: hidden; }

        /* --- 主畫面 --- */
        .header { background: white; padding: 45px 20px 15px; border-bottom: 1px solid #eee; text-align: center; }
        .selected-info { font-size: 13px; color: #007aff; margin: 5px 0; font-weight: bold; }
        .stat-grid { display: grid; grid-template-columns: repeat(3, 1fr); margin-top: 15px; }
        .stat-item label { font-size: 11px; color: #999; display: block; }
        .stat-item b { font-size: 16px; }

        .cal-container { background: white; margin: 15px; padding: 10px; border-radius: 15px; }
        .cal-grid { display: grid; grid-template-columns: repeat(7, 1fr); gap: 2px; }
        .cal-weekday { font-size: 10px; color: #ccc; text-align: center; padding: 5px 0; }
        .cal-day { height: 50px; border-radius: 8px; display: flex; flex-direction: column; align-items: center; justify-content: center; cursor: pointer; border: 1px solid transparent; }
        .cal-day.selected { border: 1.5px solid #007aff; background: #f0f7ff; }
        .day-num { font-size: 13px; }
        .day-val { font-size: 8px; color: var(--exp-color); }

        /* --- 支出輸入頁 (對應圖 8) --- */
        #input-page {
            position: fixed; top: 0; left: 0; width: 100%; height: 100%;
            background: white; transform: translateY(100%); transition: 0.3s cubic-bezier(0,0,0.2,1);
            z-index: 100; display: flex; flex-direction: column;
        }
        #input-page.active { transform: translateY(0); }

        .tab-nav { display: flex; justify-content: center; gap: 20px; padding: 15px; background: #fff; }
        .tab { padding: 5px 20px; border-radius: 15px; background: #f0f0f0; font-size: 14px; color: #666; }
        .tab.active { background: var(--green-theme); color: white; }

        /* 類別圖標區 */
        .category-scroll { flex: 1; overflow-y: auto; padding: 10px; display: grid; grid-template-columns: repeat(4, 1fr); gap: 15px; align-content: start; }
        .cat-item { text-align: center; font-size: 11px; color: #444; }
        .cat-icon { 
            width: 50px; height: 50px; background: #fff; border: 1px solid #eee; 
            border-radius: 12px; margin: 0 auto 5px; display: flex; 
            align-items: center; justify-content: center; font-size: 24px;
        }
        .cat-item.active .cat-icon { border: 2px solid var(--green-theme); background: #f9fbf9; }

        /* 計算機與標籤區 */
        .calc-section { background: var(--green-theme); border-radius: 25px 25px 0 0; padding: 10px; }
        .tags-bar { display: flex; gap: 5px; margin-bottom: 8px; }
        .tag { background: rgba(255,255,255,0.6); font-size: 10px; padding: 3px 8px; border-radius: 5px; color: #444; }
        
        .amount-row { background: white; border-radius: 10px; padding: 10px 15px; display: flex; justify-content: space-between; align-items: center; margin-bottom: 10px; }
        .amount-row span { color: #ccc; font-size: 14px; }
        .amount-row b { font-size: 22px; color: var(--exp-color); }

        .key-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 8px; }
        .key { background: rgba(255,255,255,0.2); height: 48px; border-radius: 10px; display: flex; align-items: center; justify-content: center; color: white; font-weight: bold; font-size: 18px; }
        .key.white { background: white; color: var(--green-theme); }
        .key.done { background: white; color: var(--green-theme); font-size: 14px; }

        .add-btn { position: fixed; bottom: 30px; left: 50%; transform: translateX(-50%); width: 60px; height: 60px; background: var(--green-theme); border-radius: 30px; color: white; font-size: 35px; display: flex; align-items: center; justify-content: center; box-shadow: 0 4px 15px rgba(0,0,0,0.2); }
    </style>
</head>
<body>

    <div id="home">
        <div class="header">
            <div style="font-weight:bold;">預設帳本</div>
            <div id="date-label" class="selected-info">4月24日 (週五)</div>
            <div class="stat-grid">
                <div class="stat-item"><label>總額</label><b id="total">$0</b></div>
                <div class="stat-item"><label>收入</label><b style="color:var(--income-color)">$0</b></div>
                <div class="stat-item"><label>支出</label><b id="exp-stat" style="color:var(--exp-color)">$0</b></div>
            </div>
        </div>
        <div class="cal-container">
            <div class="cal-grid" id="grid">
                <div class="cal-weekday">日</div><div class="cal-weekday">一</div><div class="cal-weekday">二</div><div class="cal-weekday">三</div><div class="cal-weekday">四</div><div class="cal-weekday">五</div><div class="cal-weekday">六</div>
            </div>
        </div>
        <div class="add-btn" onclick="openInput()">+</div>
    </div>

    <div id="input-page">
        <div class="tab-nav">
            <div class="tab active">支出</div><div class="tab">收入</div><div class="tab">轉帳</div>
        </div>
        
        <div class="category-scroll" id="cat-list">
            </div>

        <div class="calc-section">
            <div class="tags-bar">
                <div class="tag">🕒 下午 5:36</div><div class="tag">📔 預設帳本</div><div class="tag">💳 帳戶</div><div class="tag">✔️ 計入收支</div>
            </div>
            <div class="amount-row">
                <span id="note-text">+ 填寫備註</span>
                <b id="calc-val">$0</b>
            </div>
            <div class="key-grid">
                <div class="key white" onclick="press('7')">7</div><div class="key white" onclick="press('8')">8</div><div class="key white" onclick="press('9')">9</div><div class="key" onclick="press('DEL')">⌫</div>
                <div class="key white" onclick="press('4')">4</div><div class="key white" onclick="press('5')">5</div><div class="key white" onclick="press('6')">6</div><div class="key">+-×÷</div>
                <div class="key white" onclick="press('1')">1</div><div class="key white" onclick="press('2')">2</div><div class="key white" onclick="press('3')">3</div><div class="key" onclick="press('AC')">AC</div>
                <div class="key white" onclick="press('.')">.</div><div class="key white" onclick="press('0')">0</div><div class="key white" onclick="press('00')">00</div><div class="key done" onclick="save()">完成</div>
            </div>
        </div>
    </div>

    <script>
        let selectedDay = 24;
        let amount = "0";
        let records = {}; // { day: total_exp }

        // 24 個支出類別文字與 Emoji (對應圖 8)
        const categories = [
            {n:'日用品', e:'🧺'}, {n:'餐飲', e:'🍴'}, {n:'交通', e:'🚌'}, {n:'娛樂', e:'👾'}, {n:'服飾', e:'👕'}, {n:'教育', e:'🎓'},
            {n:'美容', e:'💄'}, {n:'零食', e:'🍭'}, {n:'親子', e:'👶'}, {n:'數位', e:'📷'}, {n:'社交', e:'🥳'}, {n:'旅遊', e:'🧳'},
            {n:'寵物', e:'🐱'}, {n:'居住', e:'🏠'}, {n:'汽車', e:'🚗'}, {n:'生活繳費', e:'⚡'}, {n:'菸酒', e:'🍺'}, {n:'醫療', e:'🏥'},
            {n:'美妝', e:'💅'}, {n:'遊戲', e:'🎮'}, {n:'健身', e:'🏋️'}, {n:'鞋包', e:'👠'}, {n:'居家用品', e:'🍳'}, {n:'訂閱', e:'📅'}
        ];

        function init() {
            const list = document.getElementById('cat-list');
            categories.forEach((c, i) => {
                list.innerHTML += `
                    <div class="cat-item ${i===0?'active':''}">
                        <div class="cat-icon">${c.e}</div>${c.n}
                    </div>`;
            });
            drawCal();
        }

        function drawCal() {
            const grid = document.getElementById('grid');
            document.querySelectorAll('.cal-day').forEach(d => d.remove());
            for(let i=1; i<=30; i++) {
                const d = document.createElement('div');
                d.className = 'cal-day' + (i===selectedDay?' selected':'');
                d.onclick = () => { selectedDay = i; document.getElementById('date-label').innerText = `4月${i}日`; drawCal(); };
                d.innerHTML = `<span class="day-num">${i}</span><span class="day-val">${records[i] ? '-'+records[i] : ''}</span>`;
                grid.appendChild(d);
            }
        }

        function openInput() { document.getElementById('input-page').classList.add('active'); }
        
        function press(k) {
            if(k === 'AC') amount = "0";
            else if(k === 'DEL') amount = amount.length > 1 ? amount.slice(0,-1) : "0";
            else if(amount === "0") amount = k;
            else amount += k;
            document.getElementById('calc-val').innerText = '$' + amount;
        }

        function save() {
            records[selectedDay] = (records[selectedDay] || 0) + parseFloat(amount);
            let total = 0; Object.values(records).forEach(v => total += v);
            document.getElementById('exp-stat').innerText = '$' + total;
            document.getElementById('total').innerText = '-$' + total;
            drawCal();
            document.getElementById('input-page').classList.remove('active');
            amount = "0"; document.getElementById('calc-val').innerText = '$0';
        }

        init();
    </script>
</body>
</html>
